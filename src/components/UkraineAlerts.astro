---
import { t, localePath, type Lang } from '../i18n/translations';
import { getCollection } from 'astro:content';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const alerts = (await getCollection('alerts'))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<section id="ukraine-alerts" class="bg-ivory py-12 border-b border-charcoal/10">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="flex justify-between items-end mb-8">
      <div>
        <span class="font-mono text-xs uppercase tracking-[0.12em] text-gold font-semibold">
          {t(lang, 'alerts.label')}
        </span>
        <h2 class="font-heading text-2xl font-bold text-navy mt-1">{t(lang, 'alerts.title')}</h2>
      </div>
      <a href={localePath(lang, '/publications')} class="text-sm text-steel hover:text-navy transition-colors">
        {t(lang, 'alerts.all')} &rarr;
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {alerts.map((alert) => (
        <article class="bg-white rounded-lg p-5 border border-charcoal/10 hover:shadow-md transition-shadow">
          <span class="font-mono text-[0.65rem] text-gold font-semibold uppercase">
            ALERT &middot; {alert.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
          </span>
          <h3 class="font-semibold text-navy mt-2 text-sm leading-snug">{alert.data.title}</h3>
          <p class="text-xs text-charcoal/50 mt-2">{alert.data.readTime} {t(lang, 'alerts.min_read')}</p>
        </article>
      ))}
    </div>
  </div>
</section>

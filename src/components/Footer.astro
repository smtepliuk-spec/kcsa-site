---
import { t, localePath, type Lang } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<footer class="bg-charcoal text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 mb-10">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-3">
          <img src="/logo-nobg.png" alt="KCSA" class="h-10 w-10 object-contain opacity-80" />
          <span class="font-heading font-bold text-xl tracking-wide">KCSA</span>
        </div>
        <p class="text-white/50 text-sm leading-relaxed">
          Kyiv Council on Strategic Affairs<br />
          Київська Рада зі Стратегічних Питань
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="font-mono text-[0.7rem] uppercase tracking-widest text-gold mb-4">{t(lang, 'footer.navigation')}</h3>
        <div class="space-y-2 text-sm text-white/60">
          <a href={localePath(lang, '/structure')} class="block hover:text-white transition-colors">{t(lang, 'nav.structure')}</a>
          <a href={localePath(lang, '/committees')} class="block hover:text-white transition-colors">{t(lang, 'nav.committees')}</a>
          <a href={localePath(lang, '/publications')} class="block hover:text-white transition-colors">{t(lang, 'nav.publications')}</a>
          <a href={localePath(lang, '/events')} class="block hover:text-white transition-colors">{t(lang, 'nav.events')}</a>
        </div>
      </div>

      <!-- Resources -->
      <div>
        <h3 class="font-mono text-[0.7rem] uppercase tracking-widest text-gold mb-4">{t(lang, 'footer.resources')}</h3>
        <div class="space-y-2 text-sm text-white/60">
          <a href={localePath(lang, '/#ukraine-alerts')} class="block hover:text-white transition-colors">{t(lang, 'nav.alerts')}</a>
          <a href={localePath(lang, '/donors')} class="block hover:text-white transition-colors">{t(lang, 'nav.donors')}</a>
          <a href={localePath(lang, '/reporting')} class="block hover:text-white transition-colors">{t(lang, 'nav.reporting')}</a>
        </div>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-mono text-[0.7rem] uppercase tracking-widest text-gold mb-4">{t(lang, 'footer.contacts')}</h3>
        <div class="space-y-2 text-sm text-white/60">
          <a href="mailto:info@kcsa.org.ua" class="block hover:text-white transition-colors">info@kcsa.org.ua</a>
          <a href="#" class="block hover:text-white transition-colors">LinkedIn</a>
          <a href="#" class="block hover:text-white transition-colors">WhatsApp</a>
        </div>
      </div>
    </div>

    <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row justify-between text-xs text-white/30">
      <span>{t(lang, 'footer.copyright')}</span>
      <span>{t(lang, 'footer.location')}</span>
    </div>
  </div>
</footer>

---
import { t, localePath, type Lang } from '../i18n/translations';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<section class="relative min-h-[85vh] flex items-center overflow-hidden bg-gradient-to-br from-navy to-navy-dark">
  <!-- Parallax ghost logo watermark -->
  <div
    id="hero-ghost"
    class="absolute inset-0 flex items-center justify-center pointer-events-none"
    style="will-change: transform;"
  >
    <img
      src="/logo-nobg.png"
      alt=""
      aria-hidden="true"
      class="w-[60vw] max-w-[500px] opacity-[0.04]"
      style="filter: brightness(10);"
    />
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 py-20">
    <div class="max-w-2xl">
      <span class="font-mono text-xs sm:text-sm uppercase tracking-[0.15em] text-gold font-semibold">
        {t(lang, 'hero.label')}
      </span>
      <h1 class="font-heading text-3xl sm:text-4xl md:text-5xl font-bold text-white mt-4 leading-tight tracking-wide">
        {t(lang, 'hero.heading')}
      </h1>
      <p class="font-body font-light text-white/65 text-base sm:text-lg mt-5 leading-relaxed max-w-xl">
        {t(lang, 'hero.subheading')}
      </p>
      <div class="flex flex-wrap gap-4 mt-8">
        <a
          href={localePath(lang, '/structure')}
          class="bg-gold text-navy px-7 py-3 rounded-md font-semibold hover:bg-gold/90 transition-colors"
        >
          {t(lang, 'hero.cta_about')}
        </a>
        <a
          href={localePath(lang, '/publications')}
          class="border border-white/30 text-white px-7 py-3 rounded-md hover:bg-white/10 transition-colors"
        >
          {t(lang, 'hero.cta_publications')}
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const ghost = document.getElementById('hero-ghost');
  if (ghost) {
    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      ghost.style.transform = `translateY(${scrollY * 0.3}px)`;
    }, { passive: true });
  }
</script>

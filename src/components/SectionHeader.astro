---
interface Props {
  label: string;
  title: string;
  align?: 'left' | 'center';
}

const { label, title, align = 'left' } = Astro.props;
const alignClass = align === 'center' ? 'text-center' : 'text-left';
---

<div class={alignClass}>
  <span class="font-mono text-xs uppercase tracking-[0.12em] text-gold font-semibold">
    {label}
  </span>
  <h2 class="font-heading text-2xl md:text-3xl font-bold text-navy mt-1">
    {title}
  </h2>
</div>

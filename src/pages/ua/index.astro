---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import MobileMenu from '../../components/MobileMenu.astro';
import Hero from '../../components/Hero.astro';
import UkraineAlerts from '../../components/UkraineAlerts.astro';
import NewsSlider from '../../components/NewsSlider.astro';
import EventsList from '../../components/EventsList.astro';
import Committees from '../../components/Committees.astro';
import Publications from '../../components/Publications.astro';
import DonorsReporting from '../../components/DonorsReporting.astro';
import ContactSection from '../../components/ContactSection.astro';
import Footer from '../../components/Footer.astro';

const lang = 'ua' as const;
---

<BaseLayout title="KCSA — Київська Рада зі Стратегічних Питань" lang={lang}>
  <Header lang={lang} currentPath="/ua/" />
  <MobileMenu lang={lang} />

  <main>
    <Hero lang={lang} />
    <UkraineAlerts lang={lang} />

    <!-- News + Events -->
    <section class="bg-white py-12 border-b border-charcoal/10">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
          <div class="lg:col-span-3">
            <NewsSlider lang={lang} />
          </div>
          <div class="lg:col-span-2">
            <EventsList lang={lang} />
          </div>
        </div>
      </div>
    </section>

    <Committees lang={lang} />
    <Publications lang={lang} />
    <DonorsReporting lang={lang} />
    <ContactSection lang={lang} />
  </main>

  <Footer lang={lang} />
</BaseLayout>
